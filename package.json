{
  "name": "cliq-notify",
  "version": "1.0.0",
  "description": "A custom github action to send notifications to zoho cliq",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "lint:fix": "biome check --write",
    "lint": "biome check",
    "package": "npx ncc build src/index.js -o dist --source-map",
    "package:watch": "npm run package -- --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ozii-cr/cliq-notify.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Ozii-cr/cliq-notify/issues"
  },
  "homepage": "https://github.com/Ozii-cr/cliq-notify#readme",
  "private": "true",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@biomejs/biome": "^2.3.8",
    "@vercel/ncc": "^0.38.4",
    "globals": "^17.6.0",
    "jest": "^30.2.0"
  },
  "dependencies": {
    "ci": "^2.3.0"
  }
